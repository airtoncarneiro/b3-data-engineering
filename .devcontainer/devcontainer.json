{
  "name": "airflow-dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".",
    "args": {
      "UID": "1000",
      "GID": "1000"
    }
  },
  // "service": "airflow",
  // "forwardPorts": [8080, 5555, 5432, 6379],
  // "workspaceFolder": "/opt/airflow",
  "workspaceFolder": "/workspace",
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
    "source=${localWorkspaceFolder}/airflow/dags,target=/home/airflow/dags,type=bind",
    "source=${localWorkspaceFolder}/airflow/logs,target=/home/airflow/logs,type=bind"
  ],
  "containerEnv": {
    "AIRFLOW__CORE__LOAD_EXAMPLES": "false",
    "AIRFLOW_HOME": "/home/airflow/",
    "PYTHONPATH": "/workspace:/home/airflow/dags"
  },
  "forwardPorts": [
    8080
  ],
  "remoteUser": "airflow",
  "postCreateCommand": "/tmp/init-airflow.sh",
  "postStartCommand": "tmux new-session -d -s airflow 'airflow webserver --port 8080' && tmux split-window -t airflow 'airflow scheduler'",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/opt/venv/bin/python",
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "bash",
            "args": []
          }
        },
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": true
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "initializeCommand": "cd \"${localWorkspaceFolder}\" && git config --local user.email \"$(git config user.email)\" && git config --local user.name \"$(git config user.name)\"",
  "overrideCommand": true
}