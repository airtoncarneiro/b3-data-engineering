{
	"name": "Airflow-Dev",
	"build": {
		"context": "..",
		"dockerfile": "./Dockerfile"
	},
	"workspaceFolder": "/workspaces/b3/airflow",
	"postCreateCommand": "airflow db migrate",
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.vscode-pylance",
				"ms-python.python",
				"ms-python.debugpy",
				"vscode-icons-team.vscode-icons"
			],
			"settings": {
				"debug.configuration": {
					"version": "0.2.0",
					"configurations": [
						{
							"name": "Python Debugger: Current File",
							"type": "debugpy",
							"request": "launch",
							"program": "${file}",
							"console": "integratedTerminal"
						}
					]
				}
			}
		}
	}
}